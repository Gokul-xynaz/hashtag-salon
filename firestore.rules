rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        resource.data != null && 
        getUserData().role == 'admin';
    }
    
    // Strictest security for settings document where credentials live
    match /settings/{settingId} {
      allow read, write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Security for users
    match /users/{userId} {
      allow read: if true; // Public read so slot checking and stylist assignment work
      allow write: if isAuthenticated() && 
        (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Security for services
    match /services/{serviceId} {
      allow read: if true; // Public read for service catalogue
      allow write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Security for appointments
    match /appointments/{appointmentId} {
      allow read, create: if true; // Public read/create for checking slots and booking appointments
      allow update, delete: if isAuthenticated(); // Only authenticated staff can modify/void
    }

    // Default catch-all rules for other collections
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
